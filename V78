function wS(id) { 
    document.querySelectorAll('.wiz-screen').forEach(e=>e.classList.remove('active')); 
    let t = document.getElementById(id);
    if(t) t.classList.add('active'); 
}

function wMainProfile(prof) { 
    wData.mainProfile = prof; 
    if(prof==='driver') wS('w-d1'); 
    else if(prof==='firm') wS('w-firm'); 
    else if(prof==='home') wS('w-home'); 
}

function dW(cat, val, el) { 
    wData[cat] = val; 
    el.parentElement.querySelectorAll('.opt-card').forEach(c=>{ 
        c.style.borderColor='var(--border)'; 
        c.classList.remove('selected'); 
    }); 
    el.style.borderColor='var(--driver)'; 
    el.classList.add('selected'); 
    
    if(cat==='p') { 
        let elB = document.getElementById('wd-b'); 
        if(elB) elB.style.display = (val === 'corp') ? 'block' : 'none'; 
    } 
    if(cat==='c') { 
        let elC = document.getElementById('wd-c'); 
        if(elC) elC.style.display = (val === 'own') ? 'none' : 'block'; 
    } 
    if(cat==='e') { 
        let ep = document.getElementById('wd-e-p'); 
        let ej = document.getElementById('wd-e-j'); 
        if(ep) ep.style.display = (val === 'partner') ? 'block' : 'none'; 
        if(ej) ej.style.display = (val === 'jdg') ? 'block' : 'none'; 
    } 
}

function dTogglePType(prefix) { 
    let elT = document.getElementById(`${prefix}-p-type`); 
    let val = elT ? elT.value : 'flat'; 
    let flatBox = document.getElementById(`${prefix}-p-flat-box`); 
    let pctBox = document.getElementById(`${prefix}-p-pct-box`); 
    if(flatBox) flatBox.style.display = (val === 'flat') ? 'block' : 'none'; 
    if(pctBox) pctBox.style.display = (val === 'pct') ? 'block' : 'none'; 
}

// ZAPIS KIEROWCY
function dFin() { 
    try {
        db.mainProfile = wData.mainProfile || 'driver';
        let nameEl = document.getElementById('w-name'); 
        db.userName = nameEl ? (nameEl.value || 'Kierowca') : 'Kierowca';
        
        db.drv.plat = wData.p; 
        db.drv.carType = wData.c; 
        db.drv.emp = wData.e; 
        
        let b = wData.p === 'corp' ? safeVal('wd-b-v') : 0; 
        let c = wData.c === 'own' ? 0 : safeVal('wd-c-v'); 
        
        let cTypeEl = document.getElementById('wd-c-type'); 
        let cType = wData.c === 'own' ? 'month' : (cTypeEl ? cTypeEl.value : 'month');
        
        let i = safeVal('wd-i-v'); 
        let e = 0, eTy = 'flat', ePct = 0; 
        
        if(wData.e === 'partner') { 
            let pTypeEl = document.getElementById('wd-p-type'); 
            eTy = pTypeEl ? pTypeEl.value : 'flat'; 
            if(eTy === 'flat') {
                e = safeVal('wd-p-v'); 
            } else {
                ePct = safeVal('wd-p-pct') / 100; 
            }
        } else { 
            e = safeVal('wd-j-z'); 
        } 
        
        db.drv.cfg.bC = b; 
        db.drv.cfg.cC = c; 
        db.drv.cfg.cType = cType; 
        db.drv.cfg.eC = e; 
        db.drv.cfg.iC = i; 
        db.drv.cfg.eType = eTy; 
        db.drv.cfg.ePct = ePct; 
        
        let dailyCar = (cType === 'week') ? (c / 7) : (c / 30); 
        let dailyOther = (b + e + i) / 30; 
        db.drv.cfg.fix = dailyCar + dailyOther;
        
        db.drv.cfg.tax = (wData.e === 'partner') ? 0 : safeVal('wd-j-t'); 
        db.drv.cfg.cardF = 0.015; 
        db.drv.cfg.goal = 350;
        
        db.role = 'drv'; 
        db.tab = 'term'; 
        db.init = true; 
        
        save(); 
        dSessionInit(); 
        render(); 
    } catch (err) { 
        alert("Błąd zapisu profilu: " + err.message); 
    }
}

function fFin() { db.mainProfile = wData.mainProfile; let nE = document.getElementById('w-name'); db.userName = nE ? (nE.value || 'Szefie') : 'Szefie'; let fn = document.getElementById('wf-n'); db.flt.n = fn ? (fn.value || "Flota") : "Flota"; db.role='flt'; db.tab='dash'; db.init=true; save(); render(); }
