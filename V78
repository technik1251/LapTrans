                <div id="us-p-pct-box" style="display:${d.cfg.eType==='pct'?'block':'none'}"><input type="number" id="us-epct" value="${(d.cfg.ePct*100).toFixed(0)}" placeholder="np. 50%" style="width:100%;padding:16px;background:#09090b;border:1px solid var(--driver);color:var(--driver);border-radius:14px;font-weight:bold;"></div>
            </div>

            <div class="inp-row"><div class="inp-group"><label>Podatek (%)</label><input type="number" id="us-tx" value="${(d.cfg.tax*100).toFixed(1)}" step="0.1"></div><div class="inp-group"><label>Terminal (%)</label><input type="number" id="us-cf" value="${(d.cfg.cardF*100).toFixed(1)}" step="0.1" style="color:var(--info); border-color:rgba(14,165,233,0.5);"></div></div>
            <div style="background:var(--bg); padding:15px; border-radius:12px; margin:15px 0; text-align:center;"><small style="color:var(--muted)">Twoja Dniówka stała wynosi:</small><br><strong style="color:var(--danger); font-size:1.5rem;">${d.cfg.fix.toFixed(2)} zł / dzień</strong></div>
            <button class="btn btn-driver" onclick="dSaveUS()">ZAKTUALIZUJ KOSZTY</button>
        </div>
        
        <div class="panel" style="border-color:rgba(245, 158, 11, 0.4)"><div class="p-title" style="color:var(--fuel)">Korekta Paliwa</div><div class="inp-group" style="margin-bottom:10px;"><label>Koszt przejechania 1 KM (zł)</label><input type="number" id="us-fc" value="${d.cfg.fuelPx.toFixed(2)}" step="0.01"></div><button class="btn" style="background:var(--fuel); color:#000;" onclick="dSaveFuel()">NADUPISZ KOSZT 1 KM</button></div>
        <div class="panel" style="border-color:var(--quote)"><div class="p-title" style="color:var(--quote)">Zarządzanie Danymi (Kopie)</div><div class="grid-2" style="margin-bottom:0;"><button class="btn" style="background:rgba(255,255,255,0.1); color:#fff; border:1px solid var(--border);" onclick="exportDb()">💾 Pobierz</button><button class="btn" style="background:rgba(255,255,255,0.1); color:#fff; border:1px solid var(--border);" onclick="importDb()">📂 Wgraj</button></div></div>
        <div class="panel" style="border-color:rgba(239,68,68,0.2)"><div class="p-title" style="color:var(--danger)">Reset Systemu</div><button class="btn btn-danger" style="background:rgba(239,68,68,0.15); color:var(--danger); border:none;" onclick="hardReset()">TWARDY RESET APLIKACJI</button></div>
        `;
    }
}

function dTC(t,v,el) { if(t==='s') dTSrc=v; else dTPay=v; el.parentElement.querySelectorAll('.chip').forEach(c=>{ c.style.background='rgba(255,255,255,0.05)'; c.style.borderColor='transparent'; c.style.color='var(--muted)'; }); if(v==='Voucher') { el.style.background='var(--warning)'; el.style.borderColor='var(--warning)'; el.style.color='#000'; } else if(v==='Gotówka') { el.style.background='var(--success)'; el.style.borderColor='var(--success)'; el.style.color='#000'; } else if(v==='Karta') { el.style.background='var(--info)'; el.style.borderColor='var(--info)'; el.style.color='#fff'; } else { el.style.background='var(--driver)'; el.style.borderColor='var(--driver)'; el.style.color='#fff'; } }
function dStartS() { let o=safeVal('ds-o'); if(!o) return; db.drv.odo=o; db.drv.sh={on:true, o, t:Date.now(), tr:[]}; save(); render(); }
function dQC() { let q=db.drv.q; let fC=db.drv.cfg.fuelPx; let tax=db.drv.cfg.tax; let v=0,k=0,m=0,f=0; if(dQM==='taxi') { let k1=safeVal('dqk1'); let k2=safeVal('dqk2'); m=safeVal('dqm'); let disc=safeVal('dqd'); k=k1+k2; let base=q.s+(k1*(dQN?q.t2:q.t1))+(k2*(dQN?q.t4:q.t3))+(m*(q.w/60)); v=base-(base*(disc/100)); f=k*fC; } else { k=safeVal('dqfk'); let r=safeVal('dqfr', 3.00); let elRet = document.getElementById('dqr'); let ret=elRet?parseInt(elRet.value):1; v=(k*ret)*r; f=(k*ret)*fC; } dQK=k; dQM_T=m; dQV=v; let net=v-f-(v*tax); let elT=document.getElementById('dqt'); let elP=document.getElementById('dqp'); if(elT)elT.innerText=v.toFixed(2)+" zł"; if(elP){elP.innerText="Czysty Zysk: "+net.toFixed(2)+" zł"; elP.style.color=net>=0?'var(--success)':'var(--danger)';} }
function dQB() { if(!db.drv.sh.on) return alert("Otwórz zmianę!"); if(dQV>0) { let cIdel = document.getElementById('dq-c'); let cId = cIdel ? parseInt(cIdel.value)||null : null; db.drv.sh.tr.unshift({id:Date.now(),v:dQV,k:dQK,m:dQM_T,s:db.drv.plat==='apps'?'Prywatny':'Centrala',p:'Gotówka', c:cId}); save(); db.tab='term'; render(); dLiveUpd(true); } }
function dSaveQC() { db.drv.q = { s:safeVal('dcs',9), w:safeVal('dcw',39), t1:safeVal('dct1',3.2), t2:safeVal('dct2',4), t3:safeVal('dct3',6.4), t4:safeVal('dct4',8) }; save(); dQC(); alert("Zapisano Taryfy!"); }
function calcFuelioStats() { let l=db.drv.fuel; let s={l1:0,c1:0,ck:db.drv.cfg.fuelPx}; if(l.length>=2){ let lF=l.findIndex(x=>x.isF===1); if(lF!==-1){ let pF=l.findIndex((x,i)=>i>lF&&x.isF===1); if(pF!==-1){ let d=l[lF].o-l[pF].o; if(d>0){ let tL=0,tC=0; for(let i=lF;i<pF;i++){tL+=l[i].l;tC+=l[i].v;} s.l1=(tL/d)*100; s.c1=(tC/d)*100; s.ck=tC/d; db.drv.cfg.fuelPx=s.ck; save(); } } } } return s; }
function dAF() { let o=safeVal('df-o'); let l=safeVal('df-l'); let v=safeVal('df-v'); let fEl=document.getElementById('df-f'); let f=fEl?parseInt(fEl.value):1; if(!o||!l||!v)return alert("Wypełnij dane ze stacji!"); db.drv.odo=o; db.drv.fuel.unshift({o,l,v,isF:f}); db.drv.exp.unshift({id:Date.now(), rD:new Date().toISOString(), d:`⛽ Paliwo ${l}L`, v, dt:new Date().toLocaleDateString(), ty:'f'}); save(); render(); }
function dAE() { let v=safeVal('de-v'); let cEl=document.getElementById('de-c'); let c=cEl?cEl.value:'Wydatki'; if(v) { if(c === '🛡️ Ubezpieczenie (Roczne / 12)') { let msc = v / 12; db.drv.cfg.iC = (parseFloat(db.drv.cfg.iC) || 0) + msc; db.drv.cfg.fix = (db.drv.cfg.cC + (db.drv.cfg.eType==='flat'?db.drv.cfg.eC:0) + db.drv.cfg.bC + db.drv.cfg.iC) / 30; db.drv.exp.unshift({id:Date.now(), rD:new Date().toISOString(), d:`🛡️ Polisa (+${msc.toFixed(2)}zł/mc)`, v: v, dt:new Date().toLocaleDateString(), ty:'amort'}); alert(`Rozbito polisę. Do stałych dodano +${msc.toFixed(2)} zł/msc.`); } else { db.drv.exp.unshift({id:Date.now(), rD:new Date().toISOString(), d:c, v, dt:new Date().toLocaleDateString(), ty:'e'}); } save(); render(); } }
function renderGarageHistory(expArray) { let arr = expArray || db.drv.exp; return arr.map(x => { let isF = x.ty==='f'; let isA = x.ty==='amort'; let col = isF ? 'var(--fuel)' : (isA ? 'var(--info)' : 'var(--danger)'); let pref = isA ? '' : '-'; return `<div class="log-item" style="border-left-color:${col}"><div><strong style="color:${isF||isA?'#fff':'var(--text)'}; font-size:1.05rem;">${x.d}</strong><br><small style="color:var(--muted)">${x.dt}</small></div><strong style="color:${col}">${pref}${x.v.toFixed(2)} zł</strong></div>`; }).join('') || '<div style="text-align:center;color:var(--muted);padding:10px;font-size:0.8rem;">Brak wpisów.</div>'; }
function dSaveFuel() { db.drv.cfg.fuelPx = safeVal('us-fc'); save(); render(); alert('Nadpisano koszt 1 KM!'); }

function dAddT() { let v=safeVal('dt-v'); let k=safeVal('dt-k'); let m=safeVal('dt-m'); let cIdel=document.getElementById('dt-cid'); let cId=cIdel ? parseInt(cIdel.value)||null : null; if(!v)return; db.drv.sh.tr.unshift({id:Date.now(),v,k,m,s:dTSrc,p:dTPay,c:cId}); save(); render(); dLiveUpd(true); }
function dDelT(id) { db.drv.sh.tr=db.drv.sh.tr.filter(x=>x.id!==id); save(); render(); }
function dLiveUpd(showConfetti = false) { let g=0; let cf=0; db.drv.sh.tr.forEach(x=>{ g+=x.v; if(x.p==='Karta') cf += x.v * db.drv.cfg.cardF; }); let pFee = db.drv.cfg.eType === 'pct' ? g * db.drv.cfg.ePct : 0; let n=g-(g*db.drv.cfg.tax)-pFee-cf-db.drv.cfg.fix; let dln = document.getElementById('dl-n'); if(dln) { dln.innerText=n.toFixed(2)+" zł"; dln.style.color=n>=0?'var(--success)':'var(--danger)'; } let deo = document.getElementById('de-o'); if(deo) deo.value=db.drv.odo; let goal = db.drv.cfg.goal || 350; if(showConfetti && n >= goal && (n - db.drv.sh.tr[0].v < goal)) { triggerConfetti(); } }
function triggerConfetti() { let conf = document.createElement('div'); conf.innerHTML = "🎉💸🏆🚀"; conf.style.position = 'fixed'; conf.style.top = '10%'; conf.style.left='50%'; conf.style.transform='translateX(-50%)'; conf.style.fontSize='5rem'; conf.style.zIndex='9999'; conf.style.animation = 'fadeIn 0.5s, fall 2s forwards'; document.body.appendChild(conf); setTimeout(()=>conf.remove(), 2500); }
function dEndS() { let e=safeVal('de-o'); if(!e||e<=db.drv.sh.o) return alert("Sprawdź licznik końcowy!"); let g=0; let pk=0; let cf=0; db.drv.sh.tr.forEach(x=>{ g+=x.v; pk+=x.k; if(x.p==='Karta') cf += x.v * db.drv.cfg.cardF; }); let k=e-db.drv.sh.o; let fc=k*db.drv.cfg.fuelPx; let tax=g*db.drv.cfg.tax; let pFee = db.drv.cfg.eType === 'pct' ? g * db.drv.cfg.ePct : 0; let n=g-fc-tax-pFee-cf-db.drv.cfg.fix; let hrs=(Date.now()-(db.drv.sh.t||Date.now()))/3600000; if(hrs<=0)hrs=0.1; db.drv.odo=e; db.drv.h.unshift({id:Date.now(), rD:new Date().toISOString(), dt:new Date().toLocaleDateString(), g, n, k, pk, fc, tx:tax, pF:pFee, cF:cf, h:hrs, tr:[...db.drv.sh.tr]}); db.drv.sh.on=false; db.drv.sh.tr=[]; save(); db.tab='stats'; render(); }
function dGenRep(brutto, fuel, exp, other, netto) { let m = new Date().toLocaleString('pl-PL', {month:'long', year:'numeric'}); let txt = `🚕 RAPORT ŁAPTRANS - ${db.userName}\n📆 Miesiąc: ${m}\n\n💰 Utarg Brutto: ${brutto.toFixed(2)} zł\n⛽ Paliwo: -${fuel.toFixed(2)} zł\n🛠️ Myjnie/Koszty: -${exp.toFixed(2)} zł\n📑 Prowizje i Stałe: -${other.toFixed(2)} zł\n\n✅ DO WYPŁATY (CZYSTE NETTO): ${netto.toFixed(2)} zł\n\nWygenerowano z aplikacji Łaptrans OS.`; navigator.clipboard.writeText(txt).then(()=>alert("Gotowe! Raport skopiowany.")); }
function dSaveUS() { db.userName = document.getElementById('us-name').value; db.drv.cfg.goal = safeVal('us-goal', 350); db.drv.cfg.cC = safeVal('us-cc'); db.drv.cfg.cType = document.getElementById('us-ctype').value; db.drv.cfg.bC = safeVal('us-bc'); db.drv.cfg.iC = safeVal('us-ic'); db.drv.cfg.tax = safeVal('us-tx') / 100; db.drv.cfg.cardF = safeVal('us-cf') / 100; let eTy = document.getElementById('us-etype').value; db.drv.cfg.eType = eTy; if(eTy === 'flat') { db.drv.cfg.eC = safeVal('us-ec'); db.drv.cfg.ePct = 0; } else { db.drv.cfg.eC = 0; db.drv.cfg.ePct = safeVal('us-epct') / 100; } let dailyCar = (db.drv.cfg.cType === 'week') ? (db.drv.cfg.cC / 7) : (db.drv.cfg.cC / 30); let dailyOther = (db.drv.cfg.eC + db.drv.cfg.bC + db.drv.cfg.iC) / 30; db.drv.cfg.fix = dailyCar + dailyOther; save(); render(); alert('Ustawienia zapisane!'); }
function dAddCrm() { let n = document.getElementById('dc-n').value; let ph = document.getElementById('dc-p').value; let d = safeVal('dc-d'); let r = document.getElementById('dc-r').value || ''; if(n) { db.drv.clients.unshift({id:Date.now(), n, ph, d, r, bl: false}); save(); render(); } }
function dCrmBl(id) { let c = db.drv.clients.find(x=>x.id===id); if(c) { c.bl = !c.bl; save(); render(); } }
function dCrmDel(id) { if(confirm("Usunąć klienta z bazy?")) { db.drv.clients = db.drv.clients.filter(x=>x.id!==id); save(); render(); } }

// ODPALENIE
render();
</script>
