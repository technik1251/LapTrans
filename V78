function hAction(type) { 
    let v = safeVal('h-v'); 
    let dEl = document.getElementById('h-d'); let d = dEl ? dEl.value : ''; 
    let who = window.hMem || db.home.members[0]; 
    if(type === 'exp') { 
        let c = document.getElementById('h-c').value; 
        if(!d) d = c; 
        if(v) { db.home.exp.unshift({id:Date.now(), ty:'exp', cat:c, d, v, who, dt:new Date().toLocaleDateString(), rD:new Date().toISOString()}); save(); db.tab='dash'; render(); } 
    } else { 
        if(!d) d = 'Dodatkowy Przychód'; 
        if(v) { db.home.inc.unshift({id:Date.now(), ty:'inc', d, v, who, dt:new Date().toLocaleDateString(), rD:new Date().toISOString()}); save(); db.tab='dash'; render(); } 
    } 
} 

function hCalcS() { let v = safeVal('hc-v'); let m = safeVal('hc-m'); let el = document.getElementById('hc-res'); if(v > 0 && m > 0) { let res = v / m; el.innerText = `Odkładaj ${res.toFixed(2)} zł co miesiąc.`; } else { el.innerText = "Wpisz kwotę i czas."; } }
function hAddPlan() { let dEl=document.getElementById('hp-d'); let d = dEl?dEl.value:'Plan'; let v = safeVal('hp-v'); let mEl=document.getElementById('hp-m'); let m = mEl?parseInt(mEl.value):1; if(d && v) { db.home.planned.push({id:Date.now(), d, v, m}); save(); render(); } }
function hDelPlan(id) { db.home.planned = db.home.planned.filter(x=>x.id!==id); save(); render(); }
function hPayPlan(id) {
    let plan = db.home.planned.find(x => x.id === id);
    if(plan) {
        let who = window.hMem || db.home.members[0];
        db.home.exp.unshift({ id: Date.now(), ty: 'exp', cat: '🏠 Dom / Rachunki', d: `Opłacono: ${plan.d}`, v: plan.v, who: who, dt: new Date().toLocaleDateString(), rD: new Date().toISOString() });
        db.home.planned = db.home.planned.filter(x => x.id !== id);
        save(); db.tab = 'dash'; render();
        alert(`Sukces! Kwota ${plan.v} zł za "${plan.d}" została odjęta z budżetu.`);
    }
}
function hAddMem() { let mEl=document.getElementById('h-new-mem'); let m = mEl?mEl.value.trim():''; if(m && !db.home.members.includes(m)) { db.home.members.push(m); save(); render(); } }
function hDelMem(m) { if(db.home.members.length === 1) return alert("Musi zostać przynajmniej jeden domownik!"); if(confirm(`Usunąć profil: ${m}?`)) { db.home.members = db.home.members.filter(x=>x!==m); save(); render(); } }
function hSaveUS() { db.home.sal = safeVal('hs-sal'); db.home.fix = safeVal('hs-fix'); save(); alert('Zaktualizowano budżet domowy!'); render(); }


