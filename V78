<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>V78 ŁAPTRANS | Flawless Fix</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap');

  :root {
    --bg: #09090b; --card: #18181b; --border: #27272a; --text: #f8fafc; --muted: #a1a1aa;
    --taxi: #eab308; --trans: #3b82f6; --life: #14b8a6; 
    --driver: #3b82f6; --fleet: #10b981; --cargo: #8b5cf6; --sped: #f59e0b;
    --quote: #d946ef; --fuel: #f59e0b; --home: #14b8a6; --plan: #a855f7;
    --success: #22c55e; --danger: #ef4444; --warning: #eab308; --info: #0ea5e9;
  }
  
  body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 0; overflow-x: hidden; -webkit-font-smoothing: antialiased; }
  .app-container { max-width: 500px; margin: 0 auto; min-height: 100vh; padding-bottom: 90px; position: relative; }
  
  .panel { background: var(--card); border: 1px solid var(--border); border-radius: 24px; margin: 15px; padding: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
  .p-title { font-size: 0.8rem; font-weight: 800; color: var(--muted); text-transform: uppercase; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 12px; display: flex; justify-content: space-between; align-items: center; letter-spacing: 1px;}
  .form-section { background: rgba(255,255,255,0.02); border: 1px solid var(--border); padding: 18px; border-radius: 16px; margin-bottom: 15px; }
  .fs-title { font-size: 0.75rem; text-transform: uppercase; font-weight: 800; margin-bottom: 12px; color: var(--muted); display:flex; align-items:center; gap:8px;}

  .btn { width: 100%; padding: 18px; border-radius: 16px; border: none; font-weight: 900; font-size: 1rem; cursor: pointer; text-transform: uppercase; transition: all 0.2s; margin-top: 10px; letter-spacing: 0.5px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
  .btn:active { transform: scale(0.97); }
  .btn-driver { background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff; } 
  .btn-fleet { background: linear-gradient(135deg, #10b981, #059669); color: #000; }
  .btn-cargo { background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: #fff; } 
  .btn-sped { background: linear-gradient(135deg, #f59e0b, #d97706); color: #000; }
  .btn-home { background: linear-gradient(135deg, #14b8a6, #0f766e); color: #fff; } 
  .btn-quote { background: linear-gradient(135deg, #d946ef, #c026d3); color: #fff; } 
  .btn-danger { background: rgba(239,68,68,0.1); border: 1px solid var(--danger); color: var(--danger); box-shadow: none;}
  
  .inp-row { display: flex; gap: 12px; margin-bottom: 12px; }
  .inp-group { flex: 1; display: flex; flex-direction: column; }
  .inp-group label { font-size: 0.7rem; color: var(--muted); font-weight: 600; margin-bottom: 6px; padding-left: 4px;}
  .inp-group input, .inp-group select { background: #09090b; border: 1px solid var(--border); color: #fff; padding: 16px; border-radius: 14px; text-align: left; font-size: 1.1rem; font-weight: 600; outline: none; width: 100%; box-sizing: border-box; transition: 0.3s; }
  .inp-group input:focus, .inp-group select:focus { border-color: var(--driver); box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15); }
  .big-inp { font-size: 2rem !important; padding: 20px !important; font-weight: 900 !important; text-align: center !important; letter-spacing: -1px; }

  .wiz-screen { display: none; padding: 30px 20px; min-height: 90vh; flex-direction: column; justify-content: center; animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .wiz-screen.active { display: flex; }
  @keyframes fadeIn { from {opacity:0; transform:translateY(20px);} to {opacity:1; transform:translateY(0);} }
  .w-title { font-size: 2.5rem; font-weight: 900; text-align: center; margin-bottom: 8px; letter-spacing: -1.5px; }
  .w-sub { color: var(--muted); text-align: center; margin-bottom: 35px; font-size: 1rem; font-weight: 400;}
  .opt-card { background: var(--card); border: 2px solid var(--border); border-radius: 20px; padding: 24px; margin-bottom: 15px; cursor: pointer; display: flex; align-items: center; transition: 0.2s; box-shadow: 0 4px 10px rgba(0,0,0,0.2);}
  .opt-card:active { transform: scale(0.98); }
  .opt-card.selected { border-width: 2px; background: rgba(255,255,255,0.03); }
  .opt-icon { font-size: 2.8rem; margin-right: 20px; }
  .opt-text h3 { margin: 0 0 5px 0; font-size: 1.2rem; font-weight: 800;}
  .opt-text p { margin: 0; font-size: 0.85rem; color: var(--muted); line-height: 1.4;}

  header { padding: 15px 20px; background: rgba(9, 9, 11, 0.85); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; display: flex; justify-content: space-between; align-items: center; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
  .logo { font-weight: 900; font-size: 1.2rem; letter-spacing: -0.5px; cursor:pointer; display:flex; align-items:center; gap:8px; padding:5px 10px; background:rgba(255,255,255,0.05); border-radius:12px; transition:0.2s; }
  .logo:active { transform: scale(0.95); background:rgba(255,255,255,0.1); }
  .badge { background: rgba(255,255,255,0.05); border: 1px solid var(--border); padding: 6px 12px; border-radius: 12px; font-family: 'Inter', monospace; font-size: 0.8rem; font-weight: 800; }
  .header-actions { display: flex; align-items: center; gap: 10px; }
  .settings-btn { font-size: 1.3rem; cursor: pointer; background: rgba(255,255,255,0.03); border: 1px solid var(--border); padding: 4px 10px; border-radius: 12px; transition: 0.2s; display:flex; align-items:center; justify-content:center; }
  
  .dash-hero { text-align: center; padding: 30px 0 20px; }
  .dash-hero p { margin: 0 0 8px 0; font-size: 0.75rem; font-weight: 800; color: var(--muted); text-transform: uppercase; letter-spacing: 1.5px; }
  .dash-hero h1 { margin: 0; font-size: 4rem; font-weight: 900; letter-spacing: -2.5px; line-height: 1; }
  
  .goal-bar-bg { width:100%; height:18px; background:rgba(255,255,255,0.05); border-radius:10px; overflow:hidden; margin: 15px 0 5px; position:relative; border:1px solid rgba(255,255,255,0.1);}
  .goal-bar-fill { height:100%; background:var(--driver); transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  .goal-text { font-size:0.7rem; color:var(--muted); font-weight:bold; display:flex; justify-content:space-between; text-transform:uppercase; margin-bottom:15px; }

  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; padding: 0 15px;}
  .grid-4 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; padding: 0 15px;}
  .box { background: var(--card); border: 1px solid var(--border); padding: 16px; border-radius: 16px; display: flex; flex-direction: column; justify-content: center; position: relative; box-shadow: 0 4px 10px rgba(0,0,0,0.2);}
  .box span { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; font-weight: 800; margin-bottom: 6px; }
  .box strong { font-size: 1.3rem; font-weight: 900; letter-spacing: -0.5px;}
  
  .log-item { background: var(--bg); border: 1px solid var(--border); border-left: 5px solid var(--border); border-radius: 16px; padding: 18px; margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center; transition: 0.2s;}
  .chip-box { display: flex; gap: 10px; overflow-x: auto; margin-bottom: 20px; padding-bottom: 5px; }
  .chip-box::-webkit-scrollbar { display: none; }
  .chip { padding: 12px 18px; background: rgba(255,255,255,0.03); border: 1px solid transparent; color: var(--muted); border-radius: 12px; font-size: 0.85rem; font-weight: 800; cursor: pointer; white-space: nowrap; flex: 1; text-align: center; transition: all 0.2s;}
  .mode-switch { display: flex; background: var(--bg); border-radius: 14px; border: 1px solid var(--border); padding: 5px; margin-bottom: 20px; }
  .mode-switch .m-btn { flex: 1; text-align: center; padding: 12px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; cursor: pointer; border-radius: 10px; color: var(--muted); transition: 0.3s; }
  .st-badge { padding: 6px 10px; border-radius: 8px; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; display:inline-block; letter-spacing: 0.5px;}

  .fin-row { display: flex; justify-content: space-between; padding: 14px 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.95rem; align-items: center;}
  .fin-row:last-child { border-bottom: none; }
  .fin-label { color: var(--muted); font-weight: 600;}
  .fin-val { font-weight: 800; font-size: 1.1rem; letter-spacing: -0.5px;}

  .nav { position: fixed; bottom: 0; width: 100%; max-width: 500px; background: rgba(24, 24, 27, 0.95); border-top: 1px solid var(--border); display: flex; justify-content: space-around; padding: 10px 0 20px 0; z-index: 1000; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); box-shadow: 0 -5px 20px rgba(0,0,0,0.4);}
  .nav-item { color: var(--muted); text-align: center; font-size: 0.55rem; font-weight: 800; cursor: pointer; text-transform: uppercase; flex: 1; transition: 0.2s;}
  .nav-item.active { color: var(--driver); transform: translateY(-2px);}
  .nav-item.act-home { color: var(--home); transform: translateY(-2px);}
  .nav-item.act-plan { color: var(--plan); transform: translateY(-2px);}
  .nav-item i { font-size: 1.25rem; display: block; margin-bottom: 5px; font-style: normal; }
  
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.95); z-index: 20000; padding: 20px; display: flex; flex-direction: column; justify-content:center; align-items:center; animation: fadeIn 0.3s; }
  .hidden { display: none !important; }
  
  @keyframes fall { 0% { top: 10%; opacity: 1; } 100% { top: 100%; opacity: 0; } }
  @keyframes ring { 0% { transform: rotate(0); } 10% { transform: rotate(15deg); } 20% { transform: rotate(-15deg); } 30% { transform: rotate(10deg); } 40% { transform: rotate(-10deg); } 50% { transform: rotate(0); } 100% { transform: rotate(0); } }
  .ringing { animation: ring 2s infinite; display:inline-block; }
</style>
</head>
<body>
<div id="app" class="app-container"></div>

<div id="m-switcher" class="modal-overlay hidden">
    <div class="panel" style="width:100%; max-width:400px; border-color:var(--driver);">
        <div class="p-title" style="justify-content:center; font-size:1rem; color:#fff;">Przełącz Aplikację</div>
        <div id="switcher-btns" style="display:flex; flex-direction:column;"></div>
        <button class="btn" style="background:#222; color:#fff; margin-top:10px;" onclick="document.getElementById('m-switcher').classList.add('hidden')">Zamknij Menu</button>
    </div>
</div>

<script>
// ==========================================
// 1. ZABEZPIECZONA BAZA DANYCH (V78)
// ==========================================
let defaultDb = {
    init: false, mainProfile: null, role: null, tab: 'term', filter: 'all', userName: '',
    drv: { 
        plat: 'apps', carType: 'rent', emp: 'partner', 
        cfg: { fix: 0, tax: 0, fuelPx: 0.5, bC: 0, cC: 0, cType: 'month', eC: 0, iC: 0, eType: 'flat', ePct: 0, cardF: 0.015, goal: 350 }, 
        odo: 0, q: {s:9, w:39, t1:3.2, t2:4, t3:6.4, t4:8}, 
        sh: {on: false, o: 0, t: null, tr: []}, 
        h: [], exp: [], fuel: [], clients: [] 
    },
    flt: { n: '', cars: [], tx: [] },
    crg: { n: '', fuel: 5.2, cars: [], fr: [] },
    spd: { n: '', fix: 2000, fuel: 5.2, tx: [] },
    home: { n: 'Mój Dom', sal: 0, fix: 0, exp: [], inc: [], members: [], planned: [] }
};

let db;
try {
    db = JSON.parse(localStorage.getItem('laptrans_v18_db')) || defaultDb;
    if (!db.home || !db.home.planned || !db.drv || !db.drv.cfg) {
        db = defaultDb; 
    }
} catch(e) { 
    db = defaultDb; 
}

let wData = { p: 'apps', c: 'rent', e: 'partner', mainProfile: null }; 
window.tmpFr = null; 
window.hMem = null; 
const APP = document.getElementById('app');

function save() { 
    localStorage.setItem('laptrans_v18_db', JSON.stringify(db)); 
}

// ==========================================
// 1A. KLUCZOWA FUNKCJA (NAPRAWIAJĄCA BŁĄD Z EKRANU)
// ==========================================
let dTSrc = null; let dTPay = null; let dQM = 'taxi'; let dQN = false; let dQV=0; let dQK=0; let dQM_T=0;

function dSessionInit() { 
    if(!db || !db.drv) return;
    if(!dTSrc) dTSrc = db.drv.plat === 'apps' ? 'Uber' : 'Centrala'; 
    if(!dTPay) dTPay = db.drv.plat === 'apps' ? 'Online' : 'Gotówka'; 
}

// BEZPIECZNE POBIERANIE WARTOŚCI (Zapobiega błędom formularza)
function safeVal(id, fallback = 0) {
    let el = document.getElementById(id);
    if(el && el.value) {
        let v = parseFloat(el.value);
        return isNaN(v) ? fallback : v;
    }
    return fallback;
}

function hardReset() { 
    if(confirm("UWAGA! Usunąć wszystkie dane z aplikacji?")) { 
        localStorage.clear(); 
        location.reload(); 
    } 
}

function exportDb() {
    let dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(db));
    let dlAnchorElem = document.createElement('a'); dlAnchorElem.setAttribute("href", dataStr); dlAnchorElem.setAttribute("download", "laptrans_backup.json"); dlAnchorElem.click();
}

function importDb() {
    let input = document.createElement('input'); input.type = 'file'; input.accept = '.json';
    input.onchange = e => {
        let reader = new FileReader(); reader.readAsText(e.target.files[0],'UTF-8');
        reader.onload = ev => { try { let content = JSON.parse(ev.target.result); if(content.init) { db = content; save(); location.reload(); } else alert("Błędny plik!"); } catch(err) { alert("Błąd odczytu pliku."); } }
    }
    input.click();
}

function openSwitcher() {
    let s = document.getElementById('m-switcher');
    let sBtns = document.getElementById('switcher-btns');
    let html = '';
    if (db.mainProfile === 'driver') {
        html += `<button class="btn btn-driver" style="margin-bottom:10px; font-size:0.9rem;" onclick="switchApp('drv')">🚕 Mój Panel Taxi</button>`;
        html += `<button class="btn btn-home" style="margin-bottom:10px; font-size:0.9rem;" onclick="switchApp('home')">🏠 Budżet Domowy (Zrzut zysków)</button>`;
    } else if (db.mainProfile === 'firm') {
        html += `<button class="btn btn-fleet" style="margin-bottom:10px; font-size:0.9rem;" onclick="switchApp('flt')">🏢 Partner Flotowy (Taxi)</button>`;
        html += `<button class="btn btn-cargo" style="margin-bottom:10px; font-size:0.9rem;" onclick="switchApp('crg')">🚚 Transport / Giełda</button>`;
        html += `<button class="btn btn-sped" style="margin-bottom:10px; font-size:0.9rem;" onclick="switchApp('spd')">📈 Agencja Spedycyjna</button>`;
        html += `<button class="btn btn-home" style="margin-bottom:10px; font-size:0.9rem;" onclick="switchApp('home')">🏠 Budżet Domowy</button>`;
    } else {
        html += `<button class="btn btn-home" style="margin-bottom:10px; font-size:0.9rem;" onclick="switchApp('home')">🏠 Budżet Domowy</button>`;
    }
    sBtns.innerHTML = html; 
    s.classList.remove('hidden');
}

function switchApp(newRole) { 
    db.role = newRole; 
    db.tab = 'dash'; 
    if(newRole==='drv') db.tab='term'; 
    save(); 
    document.getElementById('m-switcher').classList.add('hidden'); 
    render(); 
}

// ==========================================
// 2. GŁÓWNY ROUTER
// ==========================================
function render() {
    if(!db || !db.init) return rWiz();
    if(db.role === 'drv') return rDrv();
    if(db.role === 'flt') return rFlt();
    if(db.role === 'crg') return rCrg();
    if(db.role === 'spd') return rSped();
    if(db.role === 'home') return rHome(); 
    return rWiz();
}

// ==========================================
// 3. KREATOR STARTOWY 
// ==========================================
function rWiz() {
    let html = `
        <div id="w-main" class="wiz-screen active">
            <div class="w-title" style="color:#fff; font-size:3rem; margin-bottom:0;">ŁAPTRANS OS</div>
            <div class="w-sub" style="margin-bottom:20px;">System Zarządzania i Księgowości</div>
            <div class="wiz-inputs" style="display:block; padding:0; background:transparent; border:none; margin-bottom:20px;">
                <div class="inp-group">
                    <label style="text-align:center; font-size:0.8rem;">Jak masz na imię?</label>
                    <input type="text" id="w-name" placeholder="Twoje Imię" style="text-align:center; font-size:1.5rem; font-weight:900;" value="${db.userName||''}">
                </div>
            </div>
            <div class="opt-card" style="border-color:var(--driver)" onclick="wMainProfile('driver')">
                <div class="opt-icon">🚕</div><div class="opt-text"><h3 style="color:var(--driver)">Kierowca Taxi</h3><p>Zarobki, terminal, koszty własne.</p></div>
            </div>
            <div class="opt-card" style="border-color:var(--fleet)" onclick="wMainProfile('firm')">
                <div class="opt-icon">🏢</div><div class="opt-text"><h3 style="color:var(--fleet)">Moja Firma</h3><p>Flota, przewoźnik, spedycja.</p></div>
            </div>
            <div class="opt-card" style="border-color:var(--life)" onclick="wMainProfile('home')">
                <div class="opt-icon">🏠</div><div class="opt-text"><h3 style="color:var(--life)">Budżet Domowy</h3><p>Zarządzaj prywatnymi wydatkami.</p></div>
            </div>
        </div>

        <div id="w-firm" class="wiz-screen">
            <div class="w-title">Moduły Firmowe</div><div class="w-sub">Wybierz centrum dowodzenia.</div>
            <div class="opt-card" style="border-color:var(--fleet)" onclick="wS('w-f1')"><div class="opt-icon">🏢</div><div class="opt-text"><h3 style="color:var(--fleet)">Partner Flotowy (Taxi)</h3><p>Wynajmuję auta i ściągam raty.</p></div></div>
            <div class="opt-card" style="border-color:var(--cargo)" onclick="wS('w-c1')"><div class="opt-icon">🚚</div><div class="opt-text"><h3 style="color:var(--cargo)">Przewoźnik (TMS)</h3><p>Posiadam własne pojazdy ciężarowe/busy.</p></div></div>
            <div class="opt-card" style="border-color:var(--sped)" onclick="wS('w-s1')"><div class="opt-icon">📈</div><div class="opt-text"><h3 style="color:var(--sped)">Agencja Spedycyjna</h3><p>Kupuję i sprzedaję ładunki.</p></div></div>
            <button class="btn btn-danger" style="background:transparent;" onclick="wS('w-main')">Wróć</button>
        </div>
        
        <div id="w-home" class="wiz-screen">
            <div class="w-title" style="color:var(--life)">Budżet Rodzinny</div><div class="w-sub">Twoje osobiste finanse domowe</div>
            <div class="wiz-inputs" style="display:block;border-color:var(--life);background:transparent;padding:0;">
                <div class="inp-group" style="margin-bottom:15px;">
                    <label style="font-size:0.8rem;margin-bottom:10px;">Stała Miesięczna Wypłata (Na rękę) zł</label>
                    <input type="number" id="wh-sal" placeholder="np. 5000">
                </div>
                <div class="inp-group">
                    <label style="font-size:0.8rem;margin-bottom:10px;">Wspólne Opłaty (Czynsz, kredyt) zł/msc</label>
                    <input type="number" id="wh-fix" placeholder="np. 2500">
                </div>
            </div>
            <button class="btn btn-home" onclick="hFin()">Otwórz Portfel</button>
            <button class="btn btn-danger" style="background:transparent; margin-top:15px;" onclick="wS('w-main')">Wróć</button>
        </div>
        
        <div id="w-d1" class="wiz-screen">
            <div class="w-title">Gdzie pracujesz?</div><div class="w-sub">Krok 1 z 3</div>
            <div class="opt-card selected" onclick="dW('p','apps',this)"><div class="opt-icon">📱</div><div class="opt-text"><h3>Aplikacje (Uber/Bolt)</h3></div></div>
            <div class="opt-card" onclick="dW('p','corp',this)"><div class="opt-icon">📻</div><div class="opt-text"><h3>Korporacja / Prywatnie</h3></div></div>
            <div id="wd-b" class="wiz-inputs" style="display:none; margin-top:5px; padding:0 5px;">
                <div class="inp-group"><label>Opłata za bazę/aplikację (zł/mc)</label><input type="number" id="wd-b-v" placeholder="np. 400"></div>
            </div>
            <button class="btn btn-driver" style="margin-top:20px;" onclick="wS('w-d2')">Dalej</button>
        </div>
        
        <div id="w-d2" class="wiz-screen">
            <div class="w-title">Twoje Auto</div><div class="w-sub">Krok 2 z 3</div>
            <div class="opt-card selected" onclick="dW('c','rent',this)"><div class="opt-icon">🤝</div><div class="opt-text"><h3>Wynajem od Floty</h3></div></div>
            <div class="opt-card" onclick="dW('c','lease',this)"><div class="opt-icon">📝</div><div class="opt-text"><h3>Własne w Leasingu</h3></div></div>
            <div class="opt-card" onclick="dW('c','own',this)"><div class="opt-icon">🚗</div><div class="opt-text"><h3>Własne Spłacone</h3></div></div>
            <div id="wd-c" class="wiz-inputs" style="display:block; margin-top:5px; padding:0 5px;">
                <div class="inp-row">
                    <div class="inp-group"><label>Koszt za auto (zł)</label><input type="number" id="wd-c-v" placeholder="np. 600"></div>
                    <div class="inp-group">
                        <label>Okres rozliczenia</label>
                        <select id="wd-c-type">
                            <option value="week">Tygodniowo</option>
                            <option value="month" selected>Miesięcznie</option>
                        </select>
                    </div>
                </div>
            </div>
            <button class="btn btn-driver" onclick="wS('w-d3')">Dalej</button>
        </div>
        
